# Frontend
VITE_API_BASE=https://api.example.com
VITE_PERF_DEBUG=false

# API
API_ENV=production
CORS_ORIGINS=https://app.example.com
CORS_ALLOW_WILDCARD=false
ENFORCE_PRODUCTION_ENV=true
API_ENABLE_DOCS=false
HEALTH_DETAILED_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_MAX_TRACKED_IPS=10000
RATE_LIMIT_EVICT_FRACTION=0.10
TRUST_PROXY_IPS=127.0.0.1,::1
SIMULATION_AUTH_ENABLED=true
# Use one auth mode:
# SIMULATION_AUTH_TOKEN=replace-with-strong-random-token
# CF_ACCESS_CLIENT_ID=replace-with-cloudflare-access-id
# CF_ACCESS_CLIENT_SECRET=replace-with-cloudflare-access-secret

# Data paths (configure per host)
GLOBAL_PROJECT_ROOT=/opt/global-project
V31_DATA_ROOT=/opt/global-project/v3.1/data
V30_RAW_DATA_ROOT=/opt/global-project/v3.0/data/raw
V21_GRAPH_PATH=/opt/global-project/viz/phase3/public/data/v2_1_visualization_final.json
