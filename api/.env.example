# Data roots (override if data is not at viz/data/)
# DATA_ROOT=/path/to/viz/data
# RAW_DATA_ROOT=/path/to/viz/data/raw
# V21_GRAPH_PATH=/path/to/viz/public/data/v2_1_visualization_final.json

# Standard API settings
# API_ENV=development
# CORS_ORIGINS=http://localhost:5173
# CORS_METHODS=GET,POST,OPTIONS
# CORS_HEADERS=Accept,Accept-Language,Authorization,CF-Access-Client-Id,CF-Access-Client-Secret,Content-Language,Content-Type,X-API-Key
# CORS_EXPOSE_HEADERS=Retry-After,X-Process-Time,X-RateLimit-Limit-Hour,X-RateLimit-Limit-Minute,X-RateLimit-Remaining-Hour,X-RateLimit-Remaining-Minute
# CORS_MAX_AGE=600
# LOG_LEVEL=INFO
# API_ENABLE_DOCS=true
# HEALTH_DETAILED_ENABLED=true
# ENFORCE_PRODUCTION_ENV=false
# SECURITY_HEADERS_ENABLED=false
# SECURITY_HEADER_HSTS_MAX_AGE=31536000

# IP + rate limiting
# TRUST_PROXY_IPS=127.0.0.1,::1
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_PER_HOUR=1000
# RATE_LIMIT_MAX_TRACKED_IPS=10000
# RATE_LIMIT_EVICT_FRACTION=0.10
# GRAPH_SERVICE_GRAPH_CACHE_MAX=64
# GRAPH_SERVICE_SHAP_CACHE_MAX=128
# TEMPORAL_SERVICE_SHAP_CACHE_MAX=256
# TEMPORAL_SERVICE_GRAPH_CACHE_MAX=192
# TEMPORAL_SERVICE_CLUSTER_CACHE_MAX=128

# Simulation endpoint auth (recommended for public exposure)
# SIMULATION_AUTH_ENABLED=false
# SIMULATION_BROWSER_ORIGIN_REQUIRED=false
# SIMULATION_AUTH_TOKEN=replace-with-random-token
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=
